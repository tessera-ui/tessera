{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tessera-ui/tessera/main/docs/schemas/tessera-app.schema.json",
  "title": "Tessera App Configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "identifier": {
      "type": "string",
      "description": "Application identifier/package name used for mobile platform manifests (for Android this is the applicationId).",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*(\\.[A-Za-z][A-Za-z0-9_]*)*$"
    }
  }
}
